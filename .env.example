# Required
ENCRYPTION_KEY=          # 64-char hex string (32 bytes). Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=      # Random string, min 32 chars. Generate: openssl rand -base64 32

# Optional
DATABASE_PATH=/data/curyloop.db
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DISABLE_CLOUD_CTA=false
